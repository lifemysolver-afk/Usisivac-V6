# ╔══════════════════════════════════════════════════════════════════╗
# ║  Usisivac V6 — API Keys (sve FREE tier)                        ║
# ║  Kopiraj u .env i popuni svoje ključeve                        ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Groq (BESPLATAN, brz, llama3/mixtral) ─────────────────────────
# Registracija: https://console.groq.com/
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ── Mistral AI (BESPLATAN tier) ────────────────────────────────────
# Registracija: https://console.mistral.ai/
MISTRAL_API_KEY=YOUR_MISTRAL_KEY_HERE

# ── Google Gemini (BESPLATAN tier) ─────────────────────────────────
# Registracija: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ── OpenRouter (FREE modeli: mistral, llama, gemma) ────────────────
# Registracija: https://openrouter.ai/
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# ── Hugging Face (BESPLATAN inference API) ─────────────────────────
# Registracija: https://huggingface.co/
HF_API_KEY=YOUR_HF_KEY_HERE

# ── Podešavanja sistema ────────────────────────────────────────────
PRIMARY_LLM=groq                  # groq | mistral | gemini | openrouter
PRIMARY_MODEL=llama-3.3-70b-versatile   # Groq default
EMBEDDING_MODEL=all-MiniLM-L6-v2  # SentenceTransformers (lokalno, besplatno)
CHROMA_DB_PATH=./chroma_db
WORK_LOG_PATH=./logs/work_log.md
MAX_LOOP_ITERATIONS=100           # Non-stop petlja limit
DRIFT_THRESHOLD=0.4               # Guardian drift limit
LOG_LEVEL=INFO
