# Usisivac V6 - API Keys (sve FREE tier)
# Kopiraj u .env i popuni svoje kljuceve

# -- Groq (BESPLATAN, brz, llama3/mixtral) -------------------------
GROQ_API_KEY=gsk_your_key_here

# -- Mistral AI (BESPLATAN tier) ------------------------------------
MISTRAL_API_KEY=your_key_here

# -- Google Gemini (BESPLATAN tier) ---------------------------------
GEMINI_API_KEY=your_key_here

# -- OpenRouter (FREE modeli: mistral, llama, gemma) ----------------
OPENROUTER_API_KEY=your_key_here

# -- Hugging Face (BESPLATAN inference API) -------------------------
HF_API_KEY=hf_your_key_here

# -- Podesavanja sistema --------------------------------------------
PRIMARY_LLM=gemini
ONLY_PRIMARY_LLM=false
