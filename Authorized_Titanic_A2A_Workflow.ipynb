        "        test = pd.read_csv('/content/kiza/data/test.csv')\n",
        "\n",
        "        train = apply_sota_engineering(train)\n",
        "        test = apply_sota_engineering(test)\n",
        "\n",
        "        # Encoding Target\n",
        "        le = LabelEncoder()\n",
        "        train['target'] = le.fit_transform(train['Irrigation_Need'])\n",
