            "import xgboost as xgb\n",
            "import numpy as np\n",
            "import pandas as pd\n",
            "from sklearn.model_selection import StratifiedKFold\n",
            "\n",
            "# === XGBoost Parameters (proven for tabular competitions) ===\n",
            "xgb_params = {\n",
            "    'objective': 'binary:logistic',\n",
            "    'eval_metric': 'auc',\n",
