        "# Helper to clear system RAM before starting the large ensemble\n",
        "import gc\n",
        "def flush_memory():\n",
        "    gc.collect()\n",
        "    if 'X' in globals():\n",
        "        print(\"Memory flushed. Ready for ensemble training.\")\n",
        "\n",
        "flush_memory()"
      ]
    },
