            "\n",
            "import pandas as pd\n",
            "import numpy as np\n",
            "import os\n",
            "\n",
            "# Load data\n",
            "train = pd.read_csv('/content/kiza/data/train.csv')\n",
            "test = pd.read_csv('/content/kiza/data/test.csv')\n",
            "\n",
            "print(f\"Train shape: {train.shape}\")\n",
            "print(f\"Test shape: {test.shape}\")\n",
            "\n",
            "# 1. Distribution of target variable\n",
            "print(\"\\nTarget variable (Irrigation_Need) distribution:\")\n",
            "print(train['Irrigation_Need'].value_counts(normalize=True))\n",
            "print(train['Irrigation_Need'].value_counts())\n",
            "\n",
            "# 2. Identify numerical and categorical features\n",
            "num_features = train.select_dtypes(include=[np.number]).columns.tolist()\n",
            "cat_features = train.select_dtypes(include=['object']).columns.tolist()\n",
            "\n",
            "if 'id' in num_features:\n",
            "    num_features.remove('id')\n",
            "if 'Irrigation_Need' in cat_features:\n",
            "    cat_features.remove('Irrigation_Need')\n",
            "\n",
            "print(f\"\\nNumerical features ({len(num_features)}): {num_features}\")\n",
            "print(f\"Categorical features ({len(cat_features)}): {cat_features}\")\n",
            "\n",
            "# 3. Check for missing values\n",
            "print(\"\\nMissing values in train:\")\n",
            "print(train.isnull().sum().sum())\n",
            "print(\"\\nMissing values in test:\")\n",
            "print(test.isnull().sum().sum())\n",
            "\n",
            "# 4. Correlation between numerical features\n",
            "print(\"\\nCorrelation matrix (top 10 absolute correlations):\")\n",
            "corr_matrix = train[num_features].corr()\n",
            "upper = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))\n",
            "corrs = upper.unstack().dropna().sort_values(ascending=False)\n",
            "print(corrs.head(10))\n",
            "\n",
            "# Save feature types for later use\n",
            "import json\n",
            "feature_info = {\n",
            "    'num_features': num_features,\n",
            "    'cat_features': cat_features,\n",
            "    'target_classes': train['Irrigation_Need'].unique().tolist()\n",
            "}\n",
            "with open('feature_info.json', 'w') as f:\n",
            "    json.dump(feature_info, f)\n"
          ]
        }
